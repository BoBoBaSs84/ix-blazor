@using Microsoft.JSInterop;
@using SiemensIXBlazor.Components
@inherits IXBaseComponent
@inject IJSRuntime JSRuntime

<ix-date-input @attributes="UserAttributes" 
               class = "@Class"
               style = "@Style"
               id = "@Id"
               aria-label-calender-button="@AriaLabelCalendarButton"
               aria-label-next-month-button="@AriaLabelNextMonthButton"
               aria-label-previous-month-button="@AriaLabelPreviousMonthButton"
               value = "@Value"
               min-date = "@MinDate"
               max-date = "@MaxDate"
               disabled = "@Disabled"
               enable-top-layer = "@EnableTopLayer"
               readonly = "@Readonly"
               label = "@Label"
               name = "@Name"
               info-text = "@InfoText"
               warning-text = "@WarningText"
               valid-text = "@ValidText"
               invalid-text = "@InvalidText"
               helper-text = "@HelperText"
               format = "@Format"
               i18n-error-date-unparsable = "@I18nErrorDateUnparsable"
               locale = "@Locale"
               placeholder = "@PlaceHolder"
               required = "@Required"
               show-text-as-tooltip = "@ShowTextAsTooltip"
               show-week-numbers="@ShowWeekNumbers">

    @if (StartSlot != null)
    {
        <div slot="start">
            @StartSlot
        </div>
    }

    @if (EndSlot != null)
    {
        <div slot="end">
            @EndSlot
        </div>
    }
</ix-date-input>
