<ix-tab-item id="@Id"
             class="@GetCssClasses()"
             style="@Style"
             icon="@(string.IsNullOrEmpty(TabTitle) && !string.IsNullOrEmpty(Icon))"
             disabled="@Disabled"
             selected="@Selected"
             counter="@Counter"
             @attributes="UserAttributes">
    @if (!string.IsNullOrEmpty(Icon))
    {
        <ix-icon name="@Icon"></ix-icon>
    }
    @if (!string.IsNullOrEmpty(TabTitle))
    {
        @TabTitle
    }
    @ChildContent
</ix-tab-item>
