@using Microsoft.AspNetCore.Components
@using SiemensIXBlazor.Helpers
@namespace SiemensIXBlazor.Components

<ix-tree-item @ref="Component"
              text="@Text"
              has-children="@HasChildren"
              context="@Context"
              aria-label-chevron-icon="@AriaLabelChevronIcon"
              class="@Class"
              style="@Style">
    @ChildContent
</ix-tree-item>

@code {
    /// <summary>
    /// Reference to the HTML element
    /// </summary>
    public ElementReference Component { get; set; }

    /// <summary>
    /// Child content
    /// </summary>
    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    /// <summary>
    /// Additional CSS classes
    /// </summary>
    [Parameter]
    public string? Class { get; set; }

    /// <summary>
    /// Additional CSS styles
    /// </summary>
    [Parameter]
    public string? Style { get; set; }

    /// <summary>
    /// Text of the tree item
    /// </summary>
    [Parameter]
    public string? Text { get; set; }

    /// <summary>
    /// Whether the tree item has children
    /// </summary>
    [Parameter]
    public bool HasChildren { get; set; }

    /// <summary>
    /// Context data
    /// </summary>
    [Parameter]
    public object? Context { get; set; }

    [Parameter]
    public string? AriaLabelChevronIcon { get; set; }

    /// <summary>
    /// Toggle event callback
    /// </summary>
    [Parameter]
    public EventCallback<object> Toggle { get; set; }

    /// <summary>
    /// Item click event callback
    /// </summary>
    [Parameter]
    public EventCallback<object> ItemClick { get; set; }

    /// <summary>
    /// Additional HTML attributes
    /// </summary>
    [Parameter(CaptureUnmatchedValues = true)]
    public Dictionary<string, object>? AdditionalAttributes { get; set; }
}
